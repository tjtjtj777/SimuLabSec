TZ=Asia/Tokyo
SPRING_PROFILES_ACTIVE=prod

MYSQL_DB=simulab
MYSQL_USER=simulab
MYSQL_PASSWORD=CHANGE_TO_STRONG_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_TO_STRONG_DB_ROOT_PASSWORD

REDIS_PASSWORD=
JWT_SECRET=CHANGE_TO_STRONG_JWT_SECRET

VITE_API_BASE_URL=/api
SIMULAB_CORS_ALLOWED_ORIGINS=https://simulab.top,https://www.simulab.top

SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_SIMULAB=INFO
JAVA_OPTS=-Xms256m -Xmx768m

HTTP_HOST_PORT=80
HTTPS_HOST_PORT=443
